/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (commit only the example template)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Dev server transient log
dev-server.log

.playwright-mcp/

# Cohort bundle extracted from Hope Move platform JSON exports lives at
# `local/iih-coh12-110226.json`. Previously the entire `local/` directory
# was gitignored to keep real participant data out of the repo; the demo
# now ships the bundle in-tree so the dashboard is self-contained on any
# host. Other ad-hoc files dropped into `local/` are still ignored.
local/*
!local/iih-coh10-190325.json
!local/iih-coh11-170925.json
!local/iih-coh12-110226.json

# Ad-hoc Playwright screenshots and scratch
viewport-*.png
final-*.png
final2-*.png
cohort-*.png
hope-move dashboard.zip
docs/plan.md