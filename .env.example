# Service URLs (server-side defaults; override per environment)
COMMENT_GEN_URL=http://localhost:8001
DROPOUT_API_URL=http://localhost:8000

# Public-facing variants for client components if needed (avoid where possible)
NEXT_PUBLIC_COMMENT_GEN_URL=http://localhost:8001
NEXT_PUBLIC_DROPOUT_API_URL=http://localhost:8000

# Shared secret for HMAC-SHA256 request signing into comment_generation.
# Must match HOPE_API_SECRET on the FastAPI service. Never commit a real value.
HOPE_API_SECRET=change-me

# NextAuth v5
AUTH_SECRET=change-me
AUTH_URL=http://localhost:3000

# Comma-separated list of facilitator emails allowed to sign in via magic link
FACILITATOR_EMAILS=
