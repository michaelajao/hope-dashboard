# Hope Facilitator dashboard env. Copy to .env (consumed by docker-compose
# and `next dev` alike).
#
# Three ways to point the dashboard at the backends — set COMMENT_GEN_URL /
# DROPOUT_API_URL accordingly:
#
#   1. Local compose stack (default below):
#        COMMENT_GEN_URL=http://localhost:8001
#        DROPOUT_API_URL=http://localhost:8000
#   2. Hosted private HF Spaces (also set HF_TOKEN):
#        COMMENT_GEN_URL=https://<owner>-hope-comment-gen-api.hf.space
#        DROPOUT_API_URL=https://<owner>-hope-dropout-api.hf.space
#   3. HPC + SSH tunnel (maintainer-only; see README):
#        COMMENT_GEN_URL=http://localhost:8011

# ─── Shared HMAC secret (comment service) ──────────────────────────────
# Used by the comment service for X-HMAC-Signature verification, and by
# the dashboard's server-side proxy routes for signing. Must match the
# value the comment service runs with. Generate: openssl rand -hex 32
HOPE_API_SECRET=change-me

# Set to "disabled" for local dev / smoke tests; any other value enables
# strict HMAC checking on every signed endpoint.
HOPE_API_AUTH=disabled

# ─── Risk service (engagement_ml) ──────────────────────────────────────
# X-API-Key the dashboard sends to the risk service. Must match the
# API_KEY the service runs with. Generate: openssl rand -hex 32
HOPE_RISK_API_KEY=change-me

# ─── Hugging Face gateway ──────────────────────────────────────────────
# Read-scoped token from https://huggingface.co/settings/tokens.
# Required when the backends run as private HF Spaces (setup 2), and by
# the comment service to snapshot_download private adapters from the Hub.
HF_TOKEN=

# ─── Comment-generation service ────────────────────────────────────────
# Adapter to load: a Hub id from HOSTED_MODELS or a local id from
# MODEL_ID_TO_DIR (see comment_generation/service/generation_service.py).
HOPE_GEN_MODEL_ID=michaelajao/qwen3.5-4b-hope-forum-lora

# Set to "1" to short-circuit /generate and serve the safe deterministic
# stub (useful for UI work without a GPU on hand).
# HOPE_DISABLE_GENERATION=1

# Where comment-api probes the risk service for /health (compose uses the
# service-discovery name).
HOPE_DROPOUT_URL=http://risk-api:8000/health

# Where the engagement_reader looks for cumulative_features_panel.parquet.
# Optional — generation degrades gracefully (engagement_used: false) when
# the file is absent.
HOPE_DROPOUT_PANEL_PATH=/data/dropout_artifacts/cumulative_features_panel.parquet

# CORS allowlist on the comment-api side.
HOPE_DASHBOARD_ORIGIN=http://localhost:3000

# ─── Dashboard ─────────────────────────────────────────────────────────
# Server-side URLs the proxy routes use to reach the backends (see the
# three setups at the top of this file).
COMMENT_GEN_URL=http://localhost:8001
DROPOUT_API_URL=http://localhost:8000

# Public-facing variants for client components if needed (avoid where possible).
NEXT_PUBLIC_COMMENT_GEN_URL=http://localhost:8001
NEXT_PUBLIC_DROPOUT_API_URL=http://localhost:8000

# NextAuth v5. Generate AUTH_SECRET with: npx auth secret
# On Vercel, leave AUTH_URL unset (the platform provides the host).
AUTH_SECRET=change-me-dev-only
AUTH_URL=http://localhost:3000

# Comma-separated allowlist for facilitator emails (empty = allow any in
# dev; production requires at least one entry).
FACILITATOR_EMAILS=

# Pick "dev-allowlist" for laptop work without SMTP, or "nodemailer" once
# EMAIL_SERVER_* vars are configured.
NEXT_PUBLIC_AUTH_PROVIDER=dev-allowlist

# Optional SMTP for nodemailer magic-link
# EMAIL_SERVER_HOST=
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER=
# EMAIL_SERVER_PASSWORD=
# EMAIL_FROM=no-reply@hope.local
